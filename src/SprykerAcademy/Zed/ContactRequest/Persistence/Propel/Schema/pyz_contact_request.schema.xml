<?xml version="1.0"?>
<database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="zed"
          xsi:noNamespaceSchemaLocation="http://static.spryker.com/schema-01.xsd"
          namespace="Orm\Zed\ContactRequest\Persistence" package="src.Orm.Zed.ContactRequest.Persistence">

    <table name="pyz_contact_request" idMethod="native" allowPkInsert="true" phpName="PyzContactRequest">
        <column name="id_contact_request" required="true" type="INTEGER" primaryKey="true" autoIncrement="true"/>
        <column name="message" required="true" type="VARCHAR" size="255"/>
        <column name="fk_customer" required="false" type="INTEGER"/>
        <unique name="pyz_contact_request-message">
            <unique-column name="message"/>
            <unique-column name="fk_customer"/>
        </unique>
        <foreign-key name="pyz_contact_request-fk_customer" foreignTable="spy_customer" phpName="Customer" onDelete="CASCADE">
            <reference local="fk_customer" foreign="id_customer"/>
        </foreign-key>
        <behavior name="timestampable"/>
        <id-method-parameter value="pyz_contact_request_pk_seq"/>
    </table>

</database>
