{% extends template('page-layout-customer', 'CustomerPage') %}

{% define data = {
    messages: _view.contactRequests,
    contactRequestForm: _view.contactRequestForm,
    activePage: 'contact-requests'
} %}

{% block breadcrumbs %}{% endblock %}

{% block content %}
    {% set ajaxProviderClass = 'js-message-async-provider' %}
    {% set ajaxContentClass = 'js-message-async-content' %}

    {# Content wrapper - this entire block gets replaced after AJAX submission #}
    <div class="is-position-relative {{ ajaxContentClass }}">
        <div class="box">
            <h4>My Contact Requests</h4>

            {% if data.contactRequests is not empty %}
                <table class="table table--expand">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Message</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for contactRequest in data.contactRequests %}
                            <tr>
                                <td>{{ contactRequest.idContactRequest }}</td>
                                <td>{{ contactRequest.message }}</td>
                                <td>{{ contactRequest.createdAt | date('Y-m-d H:i') }}</td>
                                <td>
                                    <form method="post" style="display:inline">
                                        <input type="hidden" name="idContactRequest" value="{{ contactRequest.idContactRequest }}">
                                        <button type="submit"
                                                data-message-ajax-submit
                                                formaction="{{ path('customer/messages/async/delete') }}"
                                                class="button button--hollow button--alert button--small">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p>You have no contact requests yet.</p>
            {% endif %}
        </div>

        <div class="box">
            <h4>Add a New Contact Request</h4>
            <form method="post">
                <div class="form spacing-bottom">
                    {{ form_widget(data.contactRequestForm.message) }}
                </div>
                {{ form_rest(data.contactRequestForm) }}
                <button type="submit"
                        data-message-ajax-submit
                        formaction="{{ path('customer/messages/async/add') }}"
                        class="button button--expand-sm-only button--success">
                    Add Contact Request
                </button>
            </form>
        </div>

        {# Loading spinner shown during AJAX request #}
        {% include molecule('ajax-loader') with {
            attributes: {
                'provider-class-name': ajaxProviderClass,
            },
        } only %}
    </div>

    {# AJAX Provider: handles HTTP requests #}
    {% include molecule('ajax-provider') with {
        class: ajaxProviderClass,
        attributes: {
            url: '',
            method: 'POST',
        },
    } only %}

    {# AJAX Renderer: listens for response and updates the content area #}
    {% include molecule('ajax-renderer') with {
        attributes: {
            'provider-class-name': ajaxProviderClass,
            'target-class-name': ajaxContentClass,
            'mount-after-render': true,
        },
    } only %}

    {# AJAX Form Submitter: intercepts form submit and delegates to provider #}
    {% include molecule('ajax-form-submitter') with {
        attributes: {
            'trigger-attribute': 'data-message-ajax-submit',
            'provider-class-name': ajaxProviderClass,
            'event': 'click',
        },
    } only %}
{% endblock %}
